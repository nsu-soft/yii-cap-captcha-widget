{
    "name": "nsu-soft/yii-cap-captcha-widget",
    "description": "Widget for Yii views to check captcha by Cap Captcha service",
    "keywords": [
        "yii2",
        "cap",
        "captcha",
        "security",
        "widget"
    ],
    "version": "1.0-rc2",
    "type": "library",
    "license": "BSD-3-Clause",
    "support": {
        "issues": "https://github.com/nsu-soft/yii-cap-captcha-widget/issues",
        "source": "https://github.com/nsu-soft/yii-cap-captcha-widget"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.3",
        "yiisoft/yii2": "~2.0.50",
        "npm-asset/cap.js--widget": "^0.1.42"
    },
    "require-dev": {
        "codeception/codeception": "^5.3",
        "codeception/module-asserts": "^3.3",
        "codeception/module-yii2": "^2.0",
        "nsu-soft/yii-cap-captcha": "^3.0",
        "guzzlehttp/guzzle": "^7.10"
    },
    "suggest": {
        "nsu-soft/yii-cap-captcha": "Allows you to validate token for client request via the Cap Captcha API"
    },
    "autoload": {
        "psr-4": {
            "NsuSoft\\Captcha\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://asset-packagist.org"
        }
    ],
    "config": {
        "allow-plugins": {
            "yiisoft/yii2-composer": true,
            "php-http/discovery": false
        }
    }
}